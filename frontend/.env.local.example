# Frontend environment
BACKEND_URL=http://localhost:3001

# OpenRouter — powers the chat + Studio agents
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Privy — embedded treasury wallet for Sovereign Agents (optional).
# Without it, Studio runs in "demo mode" and credits are still simulated.
# Get an app id at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
