PORT=3001

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model used for chat
CLAUDE_MODEL=claude-haiku-4-5-20251001

# milady instance (optional — only needed if you have milady installed locally)
MILADY_HOST=localhost
MILADY_PORT=2138
MILADY_WS_PORT=18789

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=60
